{# Receives `trail` y `breadcrumb_inline_edit` (como la plantilla por defecto del bundle). #}
{% if trail.nodes is not empty %}
<ul class="bc-custom-fragment">
    {% for node in trail.nodes %}
        <li>
            {% if not loop.first %}<span aria-hidden="true">→</span>{% endif %}
            {% if not node.current and node.linkEnabled and node.url %}
                <a href="{{ node.url }}">{{ node.label }}</a>
            {% else %}
                <strong{% if node.current %} aria-current="page"{% endif %}>{{ node.label }}</strong>
            {% endif %}
        </li>
    {% endfor %}
</ul>
{% endif %}
{% if breadcrumb_inline_edit.show %}
<p class="bc-custom-inline-hint" style="margin-top:0.5rem;font-size:0.85rem;">
    <a href="{{ breadcrumb_inline_edit.iframe_url }}" target="_blank" rel="noopener noreferrer">Editar migas (demo plantilla custom → nueva pestaña)</a>
</p>
{% endif %}

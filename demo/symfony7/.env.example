# Breadcrumb Kit Bundle — Symfony 7 demo
# Copy to .env: cp .env.example .env

# APP_ENV: Symfony environment. Demos use `dev`.
APP_ENV=dev

# APP_DEBUG: verbose errors and Web Profiler in dev.
APP_DEBUG=1

# APP_SECRET: signing secret (use a random value locally).
APP_SECRET=change_this_secret_key_to_a_random_value

# PORT: host port published by Docker Compose (must match URL below).
PORT=8020

# DEFAULT_URI: base path for CLI URL generation (include default locale prefix used by routes).
DEFAULT_URI=http://localhost:8020/en

# MySQL (docker-compose; DB is reachable only as hostname `mysql` inside the network)
MYSQL_ROOT_PASSWORD=password
MYSQL_DATABASE=breadcrumb_kit_demo
MYSQL_USER=demo_user
MYSQL_PASSWORD=password

# DATABASE_URL is injected by docker-compose for the PHP container.

# VAR_DUMPER_SERVER: DebugBundle VarDumper target (matches docker-compose `environment`).
VAR_DUMPER_SERVER=127.0.0.1:9912

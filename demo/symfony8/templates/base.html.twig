{# Visual shell aligned with DashboardMenuBundle demo (Bootstrap 5.3 + app-header / app-layout). #}
{% trans_default_domain 'NowoBreadcrumbKitBundle' %}
<!DOCTYPE html>
<html lang="{{ app.request.locale }}">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}{{ 'demo.base.title_default'|trans }}{% endblock %}</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
    <style>
        :root {
            --sidebar-width: 14rem;
            --aside-width: 12rem;
            --content-max-width: 52rem;
        }
        body { min-height: 100vh; display: flex; flex-direction: column; background-color: #eeeeee; }
        .app-header {
            background: linear-gradient(135deg, #2c3e50 0%, #34495e 100%);
            box-shadow: 0 2px 8px rgba(0,0,0,.15);
        }
        .app-header .navbar-brand { color: #ecf0f1 !important; font-weight: 600; }
        .app-header .navbar-brand small { font-size: 0.65rem; font-weight: 400; opacity: 0.85; display: block; margin-top: 0.15rem; }
        .app-header .btn-outline-light:hover { background: rgba(255,255,255,.2); color: #fff; }
        .app-header .btn-outline-light.active {
            background: rgba(255,255,255,.28);
            border-color: rgba(255,255,255,.65);
            color: #fff;
        }

        .app-layout { display: flex; flex: 1; }
        .app-sidebar {
            width: var(--sidebar-width);
            min-width: var(--sidebar-width);
            background: #f8f9fa;
            border-right: 1px solid #dee2e6;
            padding: 1.25rem 0;
        }
        .app-aside {
            width: var(--aside-width);
            min-width: var(--aside-width);
            background: #f8f9fa;
            border-left: 1px solid #dee2e6;
            padding: 1.25rem 0;
        }
        .app-main {
            flex: 1;
            min-width: 0;
            padding: 2rem 2.5rem;
            max-width: var(--content-max-width);
            margin: 0 auto;
        }
        .app-main h1 { font-size: 1.75rem; margin-bottom: 1rem; color: #2c3e50; }
        .app-main p { color: #495057; line-height: 1.6; }
        .app-main code { background: #f1f3f5; padding: 0.2em 0.4em; border-radius: 4px; font-size: 0.9em; }

        .app-sidebar .dashboard-menu-tree,
        .app-aside .dashboard-menu-tree {
            list-style: none;
            padding: 0 0.75rem;
            margin: 0;
        }
        .app-sidebar .dashboard-menu-tree li,
        .app-aside .dashboard-menu-tree li { margin-bottom: 0.125rem; }
        .app-sidebar .dashboard-menu-tree a,
        .app-aside .dashboard-menu-tree a {
            display: inline-flex;
            align-items: center;
            padding: 0.5rem 0.75rem;
            color: #495057;
            text-decoration: none;
            border-radius: 6px;
            font-size: 0.9375rem;
        }
        .app-sidebar .dashboard-menu-tree a .bi,
        .app-aside .dashboard-menu-tree a .bi { margin-right: 0.5rem; font-size: 1.1em; }
        .app-sidebar .dashboard-menu-tree a:hover,
        .app-aside .dashboard-menu-tree a:hover { background: #e9ecef; color: #212529; }
        .app-sidebar .dashboard-menu-tree a.active,
        .app-aside .dashboard-menu-tree a.active { background: #0d6efd; color: #fff; }
        .app-sidebar .dashboard-menu-tree a.active code,
        .app-aside .dashboard-menu-tree a.active code {
            background: rgba(255,255,255,.2);
            color: #fff;
        }
        .app-sidebar .dashboard-menu-tree .navigation-header,
        .app-aside .dashboard-menu-tree .navigation-header {
            font-size: 0.7rem;
            text-transform: uppercase;
            letter-spacing: 0.05em;
            color: #6c757d;
            padding: 0.75rem 0.75rem 0.35rem;
            font-weight: 600;
            display: block;
        }
        .sidebar-title, .aside-title {
            font-size: 0.7rem;
            text-transform: uppercase;
            letter-spacing: 0.08em;
            color: #6c757d;
            padding: 0 0.75rem 0.75rem;
            font-weight: 700;
        }
        .sidebar-admin a {
            display: flex;
            align-items: center;
            padding: 0.5rem 0.75rem;
            margin: 0 0.75rem;
            color: #495057;
            text-decoration: none;
            border-radius: 6px;
            font-size: 0.9375rem;
        }
        .sidebar-admin a:hover { background: #e9ecef; color: #212529; }

        .app-footer {
            background: #f8f9fa;
            border-top: 1px solid #dee2e6;
            padding: 1rem 2rem;
            margin-top: auto;
        }
        .app-footer .footer-links {
            list-style: none;
            padding: 0;
            margin: 0;
            display: flex;
            flex-wrap: wrap;
            gap: 0.5rem 1.25rem;
            justify-content: center;
        }
        .app-footer .footer-links a {
            color: #6c757d;
            text-decoration: none;
            font-size: 0.875rem;
        }
        .app-footer .footer-links a:hover { color: #0d6efd; }
        .app-footer .footer-links a .bi { margin-right: 0.35rem; }

        /* Breadcrumb strip (bundle output) inside main */
        .demo-breadcrumb-card .breadcrumb-demo,
        .demo-breadcrumb-card .breadcrumb-admin { margin: 0; padding: 0; border: none; }
        .demo-breadcrumb-card nav[aria-label="breadcrumb"] ol.breadcrumb-list,
        .demo-breadcrumb-card ol.breadcrumb-list {
            display: flex;
            flex-direction: row;
            flex-wrap: wrap;
            align-items: center;
            list-style: none;
            margin: 0;
            padding: 0;
            padding-inline-start: 0;
            gap: 0.15rem 0.35rem;
        }
        .demo-breadcrumb-card ol.breadcrumb-list > li {
            list-style: none;
            margin: 0;
            padding: 0;
            display: flex;
            align-items: center;
        }
        .demo-breadcrumb-card ol.breadcrumb-list > li::marker { content: none; }
        .breadcrumb-app-override.breadcrumb--many .breadcrumb-list > li {
            flex-shrink: 0;
            white-space: nowrap;
        }
        @media (max-width: 960px) {
            .breadcrumb-app-override.breadcrumb--many .breadcrumb-list {
                flex-wrap: nowrap;
                overflow-x: auto;
                max-width: 100%;
                padding-bottom: 0.45rem;
                scrollbar-width: thin;
                -webkit-overflow-scrolling: touch;
            }
        }

        .demo-trail-list { list-style: decimal; margin: 1rem 0 0 1.25rem; padding: 0; color: #495057; line-height: 1.8; }
        .bc-custom-fragment {
            display: flex;
            flex-wrap: wrap;
            gap: 0.5rem;
            align-items: center;
            list-style: none;
            padding: 0;
            margin: 0;
            font-size: 0.9rem;
        }
        .bc-custom-fragment strong { color: #212529; font-weight: 600; }

        @media (max-width: 991px) {
            .app-layout { flex-direction: column; }
            .app-sidebar, .app-aside {
                width: 100%;
                min-width: 0;
                border-right: none;
                border-left: none;
                border-bottom: 1px solid #dee2e6;
            }
        }
    </style>
    {% block styles %}{% endblock %}
</head>
<body>
{% set dashboard_collections_url = breadcrumb_kit_dashboard_collections_url() %}
    <header class="navbar navbar-expand-lg app-header">
        <div class="container-fluid px-4">
            <a class="navbar-brand" href="{{ path('app_home') }}">
                {{ 'dashboard.brand'|trans }}
                <small>{{ 'demo.base.brand_sub'|trans }}</small>
            </a>
            <div class="d-flex align-items-center gap-1 flex-wrap">
                {% if app.request.attributes.get('_route') %}
                    {% set rp = app.request.attributes.get('_route_params')|default({}) %}
                    <nav class="d-flex align-items-center gap-1" aria-label="{{ 'demo.base.language_switch_aria'|trans }}">
                        <a href="{{ path(app.request.attributes.get('_route'), rp|merge({ _locale: 'en' })) }}" class="btn btn-sm btn-outline-light {{ app.request.locale == 'en' ? 'active' : '' }}">EN</a>
                        <a href="{{ path(app.request.attributes.get('_route'), rp|merge({ _locale: 'es' })) }}" class="btn btn-sm btn-outline-light {{ app.request.locale == 'es' ? 'active' : '' }}">ES</a>
                    </nav>
                {% endif %}
                {% if dashboard_collections_url %}
                    <a href="{{ dashboard_collections_url }}" class="btn btn-sm btn-outline-light">
                        <i class="bi bi-pencil-square me-1" aria-hidden="true"></i>{{ 'demo.base.edit_breadcrumbs'|trans }}
                    </a>
                {% endif %}
            </div>
        </div>
    </header>

    <div class="app-layout">
        {% include '_demo_sidebar.html.twig' %}

        <main class="app-main">
            <div class="card demo-breadcrumb-card mb-4">
                <div class="card-body py-3">
                    {% block breadcrumb %}
                        {{ breadcrumb_render() }}
                    {% endblock %}
                </div>
            </div>
            {% block body %}{% endblock %}
        </main>

        <aside class="app-aside" aria-label="{{ 'demo.base.resources_aria'|trans }}">
            <div class="aside-title">{{ 'demo.base.resources_title'|trans }}</div>
            <ul class="dashboard-menu-tree">
                <li>
                    <a href="https://github.com/nowo-tech/breadcrumb-kit-bundle" rel="noopener noreferrer" target="_blank">
                        <i class="bi bi-github" aria-hidden="true"></i>{{ 'demo.base.github'|trans }}
                    </a>
                </li>
                <li>
                    <a href="https://packagist.org/packages/nowo-tech/breadcrumb-kit-bundle" rel="noopener noreferrer" target="_blank">
                        <i class="bi bi-box-seam" aria-hidden="true"></i>{{ 'demo.base.packagist'|trans }}
                    </a>
                </li>
            </ul>
            <p class="small text-muted px-3 mt-3 mb-0">
                {{ 'demo.base.resources_note'|trans }}
            </p>
        </aside>
    </div>

    <footer class="app-footer">
        <ul class="footer-links">
            <li><a href="{{ path('app_home') }}"><i class="bi bi-house" aria-hidden="true"></i>{{ 'demo.base.footer_home'|trans }}</a></li>
            {% if dashboard_collections_url %}
                <li><a href="{{ dashboard_collections_url }}"><i class="bi bi-database" aria-hidden="true"></i>{{ 'demo.base.footer_crud'|trans }}</a></li>
            {% endif %}
        </ul>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>

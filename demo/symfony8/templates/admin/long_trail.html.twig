{% extends 'admin/base.html.twig' %}
{% trans_default_domain 'NowoBreadcrumbKitBundle' %}

{% block title %}{{ 'demo.admin_long.title'|trans }}{% endblock %}

{% block styles %}
    <style>
        .demo-deep-jumps {
            display: flex;
            flex-wrap: wrap;
            gap: 0.45rem;
            margin: 1rem 0 0;
            align-items: center;
        }
        .demo-deep-jumps a {
            font-size: 0.8rem;
            padding: 0.35rem 0.55rem;
            border-radius: 6px;
            background: rgba(28, 25, 23, 0.06);
            border-bottom: none !important;
        }
        .demo-deep-jumps a:hover {
            background: rgba(224, 122, 95, 0.15);
        }
    </style>
{% endblock %}

{% block body %}
    <h1>{{ 'demo.admin_long.heading'|trans }}</h1>
    {{ 'demo.admin_long.body_html'|trans|raw }}
    <h2>{{ 'demo.admin_long.level_heading'|trans }}</h2>
    <p><code>w{{ level }} / w{{ maxLevel }}</code></p>
    <p style="font-size:0.9rem;margin-bottom:0.35rem;">{{ 'demo.admin_long.shortcuts'|trans }}</p>
    <nav class="demo-deep-jumps" aria-label="{{ 'demo.admin_long.jump_aria'|trans }}">
        {% for i in 1..maxLevel %}
            <a href="{{ path('app_admin_long_w' ~ i) }}">w{{ i }}</a>
        {% endfor %}
    </nav>
{% endblock %}

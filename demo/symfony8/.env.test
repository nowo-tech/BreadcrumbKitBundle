# APP_ENV: Symfony environment for PHPUnit / demo tests.
APP_ENV=test

# APP_DEBUG: Debug flag in the test environment.
APP_DEBUG=1

# APP_SECRET: Test-only secret (safe placeholder; not used in production).
APP_SECRET=test-secret

# DATABASE_URL: Doctrine DSN pointing at the demo MySQL service hostname `mysql`.
DATABASE_URL="mysql://demo_user:password@mysql:3306/breadcrumb_kit_demo?serverVersion=8.0&charset=utf8mb4"

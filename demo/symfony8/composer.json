{
    "name": "nowo-tech/breadcrumb-kit-demo-symfony8",
    "description": "Demo app for Breadcrumb Kit Bundle (Symfony 8.1, FrankenPHP)",
    "type": "project",
    "license": "MIT",
    "require": {
        "php": ">=8.4",
        "doctrine/doctrine-bundle": "^3.0",
        "doctrine/orm": "^3.0",
        "nowo-tech/breadcrumb-kit-bundle": "@dev",
        "symfony/asset": "^8.0",
        "symfony/console": "^8.0",
        "symfony/dotenv": "^8.0",
        "symfony/flex": "^2.0",
        "symfony/form": "^8.0",
        "symfony/framework-bundle": "^8.0",
        "symfony/runtime": "^8.0",
        "symfony/security-csrf": "^8.0",
        "symfony/stopwatch": "^8.0",
        "symfony/translation": "^8.0",
        "symfony/twig-bundle": "^8.0",
        "symfony/validator": "^8.0",
        "symfony/yaml": "^8.0"
    },
    "require-dev": {
        "doctrine/doctrine-fixtures-bundle": "^4.0",
        "nowo-tech/twig-inspector-bundle": "^1.0",
        "symfony/debug-bundle": "^8.0",
        "symfony/web-profiler-bundle": "^8.0"
    },
    "config": {
        "allow-plugins": {
            "symfony/flex": true,
            "symfony/runtime": true
        },
        "sort-packages": true
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "scripts": {
        "auto-scripts": {
            "cache:clear": "symfony-cmd",
            "assets:install %PUBLIC_DIR%": "symfony-cmd"
        },
        "post-install-cmd": ["@auto-scripts"],
        "post-update-cmd": ["@auto-scripts"]
    },
    "conflict": {
        "symfony/symfony": "*"
    },
    "extra": {
        "symfony": {
            "allow-contrib": true,
            "require": "8.1.*",
            "docker": false
        }
    },
    "repositories": [
        {
            "type": "path",
            "url": "/var/breadcrumb-kit-bundle"
        }
    ],
    "minimum-stability": "dev",
    "prefer-stable": true
}

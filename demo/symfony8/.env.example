# In all environments, the following files are loaded if they exist (later files override earlier ones):
#   .env, .env.local, .env.$APP_ENV, .env.$APP_ENV.local
# Real environment variables win over .env files.
# Do not commit secrets. https://symfony.com/doc/current/configuration/secrets.html

# APP_ENV: Symfony environment (dev/test/prod). In this demo it is usually `dev`.
APP_ENV=dev

# APP_DEBUG: Enable/disable detailed debug output (1 in dev).
APP_DEBUG=1

# FRANKENPHP_MODE: FrankenPHP runtime mode — `classic` (one process per request) or `worker` (long-lived workers).
# Default: worker. Set classic for per-request PHP / easier hot-reload. Recreate with `docker compose up -d` after change.
FRANKENPHP_MODE=worker

# APP_SECRET: Secret for signing/tokens. Use a local-only value in development.
APP_SECRET=change_this_secret_key_to_a_random_value

# PORT: Host port mapped to the FrankenPHP (Caddy) HTTP service (see docker-compose `php` service).
PORT=8021

# DEFAULT_URI: Base URL for CLI URL generation and routing defaults; must match PORT above (include default locale).
DEFAULT_URI=http://localhost:8021/en

# MYSQL_ROOT_PASSWORD: MySQL root password for the demo `mysql` service (docker-compose).
MYSQL_ROOT_PASSWORD=password

# MYSQL_DATABASE: Database name created in the MySQL container.
MYSQL_DATABASE=breadcrumb_kit_demo

# MYSQL_USER: Application MySQL user (non-root).
MYSQL_USER=demo_user

# MYSQL_PASSWORD: Password for MYSQL_USER.
MYSQL_PASSWORD=password

# VAR_DUMPER_SERVER: Host/port for Symfony VarDumper server (optional; used by dump() in CLI/debug).
VAR_DUMPER_SERVER=127.0.0.1:9912

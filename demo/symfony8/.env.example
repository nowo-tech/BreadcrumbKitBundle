# Breadcrumb Kit Bundle — Symfony 8 demo (Symfony 8.1, PHP 8.4)
# Copy to .env: cp .env.example .env

APP_ENV=dev
APP_DEBUG=1
APP_SECRET=change_this_secret_key_to_a_random_value

# PORT: host port published by Docker Compose (must match URL below).
PORT=8021

DEFAULT_URI=http://localhost:8021/en

MYSQL_ROOT_PASSWORD=password
MYSQL_DATABASE=breadcrumb_kit_demo
MYSQL_USER=demo_user
MYSQL_PASSWORD=password

VAR_DUMPER_SERVER=127.0.0.1:9912

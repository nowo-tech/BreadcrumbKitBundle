# Local environment (do not version secrets / machine-specific overrides)
/.env
/.env.dev
/.env.local
/.env.local.php
/.env.*.local

# Dependencies
/vendor/

# Caches, logs, and runtime
/var/
/.phpunit.cache/
*.log

# Symfony public assets and secrets
/public/bundles/
/config/secrets/

# Demo MySQL data (Docker volume bind)
/.data/

# Archives / compressed (REQ-GITIGNORE-001)
*.zip
*.tar
*.tar.gz
*.tgz
*.rar
*.7z

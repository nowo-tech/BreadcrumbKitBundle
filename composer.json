{
    "name": "nowo-tech/breadcrumb-kit-bundle",
    "description": "Symfony bundle: configurable breadcrumb trails (route matching, i18n, optional links, collection-level presentation).",
    "type": "symfony-bundle",
    "license": "MIT",
    "keywords": [
        "symfony",
        "symfony-bundle",
        "breadcrumb",
        "navigation",
        "i18n"
    ],
    "homepage": "https://github.com/nowo-tech/BreadcrumbKitBundle",
    "support": {
        "issues": "https://github.com/nowo-tech/BreadcrumbKitBundle/issues",
        "source": "https://github.com/nowo-tech/BreadcrumbKitBundle"
    },
    "authors": [
        {
            "name": "Héctor Franco Aceituno",
            "email": "hectorfranco@nowo.tech",
            "homepage": "https://github.com/HecFranco",
            "role": "Developer"
        }
    ],
    "require": {
        "php": ">=8.2 <8.6",
        "doctrine/doctrine-bundle": "^2.8 || ^3.0",
        "doctrine/orm": "^2.13 || ^3.0",
        "psr/cache": "^3.0",
        "symfony/asset": "^7.0 || ^8.0",
        "symfony/config": "^7.0 || ^8.0",
        "symfony/dependency-injection": "^7.0 || ^8.0",
        "symfony/form": "^7.0 || ^8.0",
        "symfony/framework-bundle": "^7.0 || ^8.0",
        "symfony/http-foundation": "^7.0 || ^8.0",
        "symfony/http-kernel": "^7.0 || ^8.0",
        "symfony/routing": "^7.0 || ^8.0",
        "symfony/security-core": "^7.0 || ^8.0",
        "symfony/security-csrf": "^7.0 || ^8.0",
        "symfony/twig-bundle": "^7.0 || ^8.0",
        "symfony/validator": "^7.0 || ^8.0",
        "symfony/yaml": "^7.0 || ^8.0"
    },
    "suggest": {
        "symfony/framework-bundle": "Profiler data collector (Symfony 7.2+): TemplateAwareDataCollectorInterface lives here.",
        "symfony/web-profiler-bundle": "Registers the Breadcrumb Kit panel in the Symfony profiler (dev)."
    },
    "require-dev": {
        "friendsofphp/php-cs-fixer": "^3.0",
        "phpstan/extension-installer": "^1.0",
        "phpstan/phpstan": "^2.0",
        "phpstan/phpstan-phpunit": "^2.0",
        "phpstan/phpstan-symfony": "^2.0",
        "phpunit/phpunit": "^11.0",
        "rector/rector": "^2.0"
    },
    "autoload": {
        "psr-4": {
            "Nowo\\BreadcrumbKitBundle\\": "src/"
        },
        "files": [
            "src/polyfill-template-aware-data-collector.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Nowo\\BreadcrumbKitBundle\\Tests\\": "tests/"
        }
    },
    "config": {
        "platform": {
            "php": "8.2.0"
        },
        "sort-packages": true,
        "allow-plugins": {
            "phpstan/extension-installer": true,
            "rector/rector": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "archive": {
        "exclude": ["/demo", "/.cursor"]
    },
    "scripts": {
        "test": "phpunit --colors=always",
        "test-coverage": "phpunit --colors=always --coverage-html coverage --coverage-clover coverage.xml --coverage-text=coverage-output.txt && sh .scripts/php-coverage-percent.sh coverage-output.txt",
        "coverage-check": "phpunit --colors=always --coverage-text=coverage-output.txt --coverage-clover coverage.xml && sh .scripts/coverage-fail-under.sh coverage-output.txt 99",
        "cs-check": "php-cs-fixer fix --dry-run --diff --config=.php-cs-fixer.dist.php",
        "cs-fix": "php-cs-fixer fix --config=.php-cs-fixer.dist.php",
        "rector": "rector process",
        "rector-dry": "rector process --dry-run --no-progress-bar",
        "phpstan": "phpstan analyse --memory-limit=512M",
        "qa": [
            "@cs-check",
            "@test"
        ]
    }
}

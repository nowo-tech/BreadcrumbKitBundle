{#
  Default breadcrumb markup + optional inline editor (modal + iframe al dashboard).
  Override: templates/bundles/NowoBreadcrumbKitBundle/breadcrumb.html.twig
  Variables: trail (BreadcrumbTrailView), breadcrumb_inline_edit { show, iframe_url, modal_title }
#}
{% trans_default_domain 'NowoBreadcrumbKitBundle' %}
{% set has_trail = trail.nodes is not empty %}
{% if has_trail or breadcrumb_inline_edit.show %}
<div class="breadcrumb-kit"{% if breadcrumb_inline_edit.show %} data-breadcrumb-kit-inline-wrap="1"{% endif %}>
  {% if has_trail %}
  <nav class="{{ trail.classList|default('breadcrumb') }}" aria-label="{{ 'breadcrumb.aria_label'|trans }}"{% if trail.responsiveConfig.breakpoint is defined %} data-breadcrumb-breakpoint="{{ trail.responsiveConfig.breakpoint }}"{% endif %}>
    <ol class="breadcrumb-list">
      {% for node in trail.nodes %}
        {% if not loop.first %}
          <li class="{{ trail.classSeparator|default('breadcrumb-separator') }}" aria-hidden="true">{% if trail.separatorIcon %}<span class="breadcrumb-sep-icon">{{ trail.separatorIcon }}</span>{% else %}<span>/</span>{% endif %}</li>
        {% endif %}
        <li class="{{ trail.classItem|default('breadcrumb-item') }}{% if node.current %} {{ trail.classCurrent|default('is-current') }}{% endif %}">
          {% if not node.current and node.linkEnabled and node.url %}
            <a href="{{ node.url }}">{% if node.icon %}<span class="breadcrumb-icon" aria-hidden="true">{{ node.icon }}</span> {% endif %}{{ node.label }}</a>
          {% else %}
            <span{% if node.current %} aria-current="page"{% endif %}>{% if node.icon %}<span class="breadcrumb-icon" aria-hidden="true">{{ node.icon }}</span> {% endif %}{{ node.label }}</span>
          {% endif %}
        </li>
      {% endfor %}
    </ol>
  </nav>
  {% endif %}
  {% if breadcrumb_inline_edit.show %}
  <div class="breadcrumb-kit__inline-toolbar">
    <button type="button" class="breadcrumb-kit__inline-open" data-bk-inline-open aria-haspopup="dialog">{{ 'breadcrumb.inline_edit.open'|trans }}</button>
    <dialog class="breadcrumb-kit__dialog" data-bk-inline-dialog aria-labelledby="breadcrumb-kit-inline-title">
      <div class="breadcrumb-kit__dialog-bar">
        <h2 id="breadcrumb-kit-inline-title" class="breadcrumb-kit__dialog-title">{{ breadcrumb_inline_edit.modal_title }}</h2>
        <button type="button" class="breadcrumb-kit__dialog-close" data-bk-inline-close autofocus>{{ 'breadcrumb.inline_edit.close'|trans }}</button>
      </div>
      <iframe class="breadcrumb-kit__iframe" src="{{ breadcrumb_inline_edit.iframe_url }}" title="{{ breadcrumb_inline_edit.modal_title }}"></iframe>
    </dialog>
  </div>
  <style>
    .breadcrumb-kit { display: flex; flex-wrap: wrap; align-items: center; gap: 0.5rem 0.75rem; }
    .breadcrumb-kit__inline-toolbar { flex: 0 0 auto; }
    .breadcrumb-kit__inline-open {
      font: inherit; font-size: 0.8rem; padding: 0.25rem 0.55rem; border-radius: 6px;
      border: 1px solid rgba(0,0,0,.2); background: #f8fafc; cursor: pointer; color: #0f172a;
    }
    .breadcrumb-kit__inline-open:hover { background: #e2e8f0; }
    .breadcrumb-kit__dialog { border: none; border-radius: 10px; padding: 0; max-width: min(96vw, 720px); width: 100%; box-shadow: 0 18px 48px rgba(0,0,0,.22); }
    .breadcrumb-kit__dialog::backdrop { background: rgba(15,23,42,.45); }
    .breadcrumb-kit__dialog-bar { display: flex; align-items: center; justify-content: space-between; gap: 0.75rem; padding: 0.65rem 0.85rem; border-bottom: 1px solid #e2e8f0; background: #f8fafc; }
    .breadcrumb-kit__dialog-title { margin: 0; font-size: 1rem; font-weight: 600; color: #0f172a; }
    .breadcrumb-kit__dialog-close { font: inherit; font-size: 0.8rem; padding: 0.2rem 0.5rem; border-radius: 6px; border: 1px solid #cbd5e1; background: #fff; cursor: pointer; }
    .breadcrumb-kit__iframe { display: block; width: 100%; height: min(72vh, 640px); border: 0; background: #fff; }
  </style>
  <script>
    (function () {
      var wrap = document.querySelector('[data-breadcrumb-kit-inline-wrap="1"]');
      if (!wrap) return;
      var openBtn = wrap.querySelector('[data-bk-inline-open]');
      var dlg = wrap.querySelector('[data-bk-inline-dialog]');
      var closeBtn = wrap.querySelector('[data-bk-inline-close]');
      if (!openBtn || !dlg) return;
      openBtn.addEventListener('click', function () { if (dlg.showModal) dlg.showModal(); });
      closeBtn && closeBtn.addEventListener('click', function () { dlg.close(); });
    })();
  </script>
  {% endif %}
</div>
{% endif %}

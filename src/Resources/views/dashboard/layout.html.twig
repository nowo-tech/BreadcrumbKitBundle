{% trans_default_domain 'NowoBreadcrumbKitBundle' %}
<!DOCTYPE html>
<html lang="{{ app.request.locale|default('en') }}">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block dashboard_title %}{{ 'dashboard.title'|trans }}{% endblock %} — {{ 'dashboard.title_suffix'|trans }}</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    {% block dashboard_head %}
    <style>
        {# Tom Select dropdown appended to body must stack above Bootstrap 5 modals (z-index 1055). #}
        body > .ts-dropdown { z-index: 1060; }
    </style>
    {% endblock %}
</head>
<body class="bg-light">
    {% set _bk_dr = dashboard_routes|default({}) %}
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark">
        <div class="container-fluid">
            <a class="navbar-brand" href="{{ path(_bk_dr.collections_index|default('nowo_breadcrumb_kit_dashboard_collections_index')) }}">{{ 'dashboard.title'|trans }}</a>
        </div>
    </nav>
    <main class="container-fluid py-4">
        {% block nowo_breadcrumb_kit_content %}{% endblock %}
    </main>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    {% block dashboard_scripts %}{% endblock %}
    <script src="{{ asset('bundles/nowobreadcrumbkit/js/dashboard.js') }}" defer></script>
    <script>
    window.breadcrumbKitI18n = {
        loading: {{ 'dashboard.loading'|trans|json_encode|raw }},
        errorLoadingForm: {{ 'dashboard.error_loading_form'|trans|json_encode|raw }},
        defaultCollectionModalTitle: {{ 'dashboard.collection_modal_title'|trans|json_encode|raw }},
        defaultItemModalTitle: {{ 'dashboard.item_modal_title'|trans|json_encode|raw }},
        deleteCollectionConfirm: {{ 'dashboard.delete_collection_confirm'|trans|json_encode|raw }},
        deleteItemConfirm: {{ 'dashboard.delete_item_confirm'|trans|json_encode|raw }}
    };
    window.__breadcrumbKitDashboard = window.__breadcrumbKitDashboard || {};
    window.__breadcrumbKitDashboard.importPartialUrl = {{ (path(_bk_dr.import|default('nowo_breadcrumb_kit_dashboard_import')) ~ '?_partial=1')|json_encode|raw }};
    window.__breadcrumbKitDashboard.dashboardBase = {{ path(_bk_dr.collections_index|default('nowo_breadcrumb_kit_dashboard_collections_index'))|json_encode|raw }};
    </script>
</body>
</html>
